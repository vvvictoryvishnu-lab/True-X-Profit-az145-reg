<!DOCTYPE html>
<html lang="ta">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - TrueX Matrix Pro</title>
  <style>
    body { font-family: 'Segoe UI', sans-serif; margin:0; background:#0a001f; color:#eee; }
    .login-box, .dashboard { max-width: 500px; margin: 80px auto; padding: 40px; background:rgba(0,0,0,0.9); border:1px solid #00ff9d; border-radius:15px; text-align:center; }
    input { width:100%; padding:15px; margin:12px 0; background:#1a0033; border:1px solid #00ff9d; color:white; border-radius:8px; font-size:1.1rem; }
    button { width:100%; padding:16px; font-size:1.3rem; background:linear-gradient(45deg,#00ff9d,#00ccff); color:black; border:none; border-radius:10px; cursor:pointer; font-weight:bold; margin-top:10px; }
    .logout { background:#ff3366; color:white; width:auto; padding:10px 20px; }
  </style>
</head>
<body>

  <!-- Login -->
  <div id="loginPage">
    <div class="login-box">
      <h2>🔐 ADMIN CONTROL PANEL</h2>
      <p>TrueX Matrix Pro</p>
      <input type="text" id="username" placeholder="Username" value="admin">
      <input type="password" id="password" placeholder="Password">
      <button onclick="login()">LOGIN TO ADMIN PANEL</button>
      <p style="margin-top:20px; color:#888;">Default: admin / admin123</p>
    </div>
  </div>

  <!-- Dashboard -->
  <div id="dashboardPage" style="display:none;">
    <div style="background: linear-gradient(90deg, #00ff9d, #00ccff); color:#000; padding:20px; text-align:center; font-size:1.8rem; font-weight:bold;">
      TRUE X MATRIX PRO - ADMIN CONTROL PANEL
    </div>
    
    <div style="max-width:1450px; margin:20px auto; padding:20px; text-align:right;">
      <button class="logout" onclick="logout()">LOGOUT</button>
    </div>

    <div class="login-box" style="max-width:1450px; text-align:left;">
      <h2>Welcome Admin (admin@truexprofit.com)</h2>
      <!-- Pending Leads & Active Users Tables இங்கே வரும் (முன்பு இருந்த Code) -->
      <p>Full Control System Active</p>
    </div>
  </div>

  <script>
    function login() {
      const user = document.getElementById('username').value;
      const pass = document.getElementById('password').value;

      if (user === "admin" && pass === "admin123") {
        document.getElementById('loginPage').style.display = "none";
        document.getElementById('dashboardPage').style.display = "block";
      } else {
        alert("❌ தவறான Password");
      }
    }

    function logout() {
      if (confirm("Logout செய்ய வேண்டுமா?")) {
        document.getElementById('dashboardPage').style.display = "none";
        document.getElementById('loginPage').style.display = "block";
        document.getElementById('password').value = "";
      }
    }
  </script>
</body>
</html>
